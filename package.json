{
  "name": "primevue-theme-builder",
  "version": "0.1.0",
  "type": "module",
  "homepage": "https://dr-wade.github.io/primevue-theme-builder/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dr-wade/primevue-theme-builder.git"
  },
  "bugs": {
    "url": "https://github.com/dr-wade/primevue-theme-builder/issues"
  },
  "packageManager": "pnpm@10.30.3",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts && vue-tsc -p tsconfig.build.json --emitDeclarationOnly",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "primevue": "^4.5.4"
  },
  "peerDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tailwindcss-primeui": "^0.6.0",
    "vue": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "@tailwindcss/vite": {
      "optional": true
    },
    "tailwindcss-primeui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-vue": "^5.2.0",
    "primeicons": "^7.0.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^5.9.3",
    "vite": "^6.2.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.28",
    "vue-tsc": "^2.2.12"
  }
}
